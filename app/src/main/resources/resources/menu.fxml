<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="18"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.cs.mpgc.rpg129696.view.MenuController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="TOXIC RAIN"
           style="-fx-font-size: 30px; -fx-font-weight: bold;"/>

    <Button text="Nuova Partita"
            prefWidth="220" style="-fx-font-size: 15px;"
            onAction="#onNuovaPartita"/>

    <Button text="Carica Partita"
            prefWidth="220" style="-fx-font-size: 15px;"
            onAction="#onCaricaPartita"/>

    <Button text="Esci"
            prefWidth="220" style="-fx-font-size: 15px;"
            onAction="#onEsci"/>

</VBox>